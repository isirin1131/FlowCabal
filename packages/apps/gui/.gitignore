# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build/*
# launcher.ts 静态 import build/gui-assets.tar；保留占位文件，
# CI download-artifact 时会覆盖为真 tarball（不入 commit）
!/build/gui-assets.tar

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# flowcabal cache
.flowcabal-project-cache/
# engine 运行时数据 —— 必须用前导斜杠限定为项目根的 memory/，
# 否则 Tailwind v4（默认读 .gitignore 决定扫源）会跳过 src/app/memory/ 路由
# 的源文件，导致那个页面所有新写的工具类不进 CSS。
/memory/
# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
