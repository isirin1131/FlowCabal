{
  "name": "gui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "bundle:launcher": "esbuild launcher.ts --bundle --platform=node --target=node22 --format=cjs --outfile=build/launcher.bundle.js --external:node:sea",
    "sea:check-node": "node -e \"const v=process.versions.node.split('.').map(Number);if(v[0]!==22||v[1]<20){console.error('SEA build needs Node 22.20.x LTS (current: '+process.versions.node+'). Other versions build incompatible blob (BlobDeserializer segfault). Download from nodejs.org/dist/v22.20.0/ to /tmp and use full path.');process.exit(1)}\"",
    "sea:blob": "bun run sea:check-node && node --experimental-sea-config sea-config.json",
    "sea:build": "bun run bundle:launcher && bun run sea:blob"
  },
  "dependencies": {
    "@flowcabal/engine": "workspace:*",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@xyflow/react": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "lucide-react": "^1.11.0",
    "nanoid": "^5.1.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.4.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/dagre": "^0.7",
    "esbuild": "^0.25.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
